@page
@model Lab6_Variant7.Pages_Cities.IndexModel

@{
    ViewData["Title"] = "Города";
}

<h1>Города</h1>

<p>
    <a asp-page="Create">Добавить город</a> |
    <a asp-page="/Index" class="btn btn-secondary btn-sm">На главную</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Population)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Mayor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Region)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Area)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.City) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Population)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Mayor)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Region.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Area)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Редактировать</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Детали</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>
