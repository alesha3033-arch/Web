@page
@model Lab6_Variant7.Pages_Regions.IndexModel

@{
    ViewData["Title"] = "Области";
}

<h1>Области</h1>

<p>
    <a asp-page="Create">Добавить область</a> |
    <a asp-page="/Index" class="btn btn-secondary btn-sm">На главную</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Region[0].SettlementsCount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Region[0].Leadership)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Region[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Region[0].Area)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Region) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SettlementsCount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Leadership)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Area)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Редактировать</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Детали</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>
