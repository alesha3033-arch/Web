@page
@model Lab6_Movies.Pages_Movies.IndexModel

@{
    ViewData["Title"] = "Фильмы";
}

<div class="search-container">
    <div class="search-header">
        <h1 style="margin: 0;">🎬 Фильмы</h1>
        <a asp-page="Create" class="btn btn-primary">+ Добавить фильм</a>
    </div>

    <form>
        <div class="form-group" style="margin-bottom: 0;">
            <div class="input-group">
                <input type="text" name="SearchString" value="@Model.SearchString" 
                       class="form-control" placeholder="Поиск по названию фильма..." />
                <button type="submit" class="btn btn-primary">🔍 Поиск</button>
            </div>
        </div>
    </form>
</div>

@if (Model.Movie.Count == 0)
{
    <div style="text-align: center; padding: 4rem 2rem; background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🎥</div>
        <h3 style="color: var(--text-dark); margin-bottom: 1rem;">Фильмы не найдены</h3>
        <p style="color: var(--text-light); margin-bottom: 2rem;">Начните добавлять фильмы в вашу коллекцию</p>
        <a asp-page="Create" class="btn btn-primary">Добавить первый фильм</a>
    </div>
}
else
{
    <div class="movie-grid">
        @foreach (var item in Model.Movie)
        {
            <div class="movie-card">
                <h3 class="movie-title">@Html.DisplayFor(modelItem => item.Title)</h3>
                
                <div class="movie-info">
                    <div class="movie-info-item">
                        <span class="movie-info-label">📅 Дата выхода:</span>
                        <span>@item.ReleaseDate.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="movie-info-item">
                        <span class="movie-info-label">🎭 Жанр:</span>
                        <span>@Html.DisplayFor(modelItem => item.Genre)</span>
                    </div>
                    <div class="movie-info-item">
                        <span class="movie-info-label">💰 Цена:</span>
                        <span>@item.Price.ToString("C")</span>
                    </div>
                    <div class="movie-info-item">
                        <span class="movie-info-label">⭐ Рейтинг:</span>
                        <span class="movie-rating">@Html.DisplayFor(modelItem => item.Rating)</span>
                    </div>
                </div>

                <div class="movie-actions">
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="action-edit">✏️ Редактировать</a>
                    <a asp-page="./Details" asp-route-id="@item.Id" class="action-details">👁️ Детали</a>
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="action-delete">🗑️ Удалить</a>
                </div>
            </div>
        }
    </div>
}
