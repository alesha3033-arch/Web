@page
@model Lab6_Movies.Pages_Movies.CreateModel

@{
    ViewData["Title"] = "Добавить фильм";
}

<div style="max-width: 600px; margin: 0 auto;">
    <div style="margin-bottom: 2rem;">
        <a asp-page="Index" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">
            ← Назад к списку
        </a>
    </div>

    <div style="background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🎬</div>
            <h1>Добавить новый фильм</h1>
            <p style="color: var(--text-light);">Заполните информацию о фильме</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="background: #fee; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;"></div>
            
            <div class="form-group">
                <label asp-for="Movie.Title" class="control-label">
                    <span style="color: #ef4444;">*</span> 📝 Название фильма
                </label>
                <input asp-for="Movie.Title" class="form-control" placeholder="Введите название фильма" aria-required="true"/>
                <span asp-validation-for="Movie.Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Movie.ReleaseDate" class="control-label">
                    <span style="color: #ef4444;">*</span> 📅 Дата выхода
                </label>
                <input asp-for="Movie.ReleaseDate" class="form-control" type="date" aria-required="true"/>
                <span asp-validation-for="Movie.ReleaseDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Movie.Genre" class="control-label">
                    <span style="color: #ef4444;">*</span> 🎭 Жанр
                </label>
                <input asp-for="Movie.Genre" class="form-control" placeholder="Например: Боевик, Комедия, Драма" aria-required="true"/>
                <span asp-validation-for="Movie.Genre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Movie.Price" class="control-label">
                    💰 Цена
                </label>
                <input asp-for="Movie.Price" class="form-control" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="Movie.Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Movie.Rating" class="control-label">
                    <span style="color: #ef4444;">*</span> ⭐ Рейтинг
                </label>
                <input asp-for="Movie.Rating" class="form-control" placeholder="Например: PG-13, R, G" aria-required="true"/>
                <span asp-validation-for="Movie.Rating" class="text-danger"></span>
            </div>

            <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #e5e7eb;">
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    ✅ Создать фильм
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
